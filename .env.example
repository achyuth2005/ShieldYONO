# ShieldYONO Environment Configuration
# Copy this file to .env and update values as needed

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Redis (optional, falls back gracefully) ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SAFE=3600
CACHE_TTL_SUSPICIOUS=600
CACHE_TTL_PHISHING=300

# --- Database ---
DATABASE_URL=sqlite:///backend/shieldyono.db

# --- Timeouts ---
MAX_REDIRECTS=5
REQUEST_TIMEOUT=10
WHOIS_TIMEOUT=5
DNS_TIMEOUT=5
